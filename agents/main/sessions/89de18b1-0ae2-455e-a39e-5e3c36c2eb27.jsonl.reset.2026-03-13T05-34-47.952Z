{"type":"message","id":"ac8afb52","parentId":"7ace4555","timestamp":"2026-03-13T02:33:47.223Z","message":{"role":"toolResult","toolCallId":"call_df0766a5bdf74a94a148df99","toolName":"exec","content":[{"type":"text","text":"Usage: clawhub explore [options]\n\nBrowse latest updated skills from the registry\n\nOptions:\n  --limit <n>     Number of skills to show (max 200) (default: 25)\n  --sort <order>  Sort by newest, downloads, rating, installs, installsAllTime,\n                  or trending (default: \"newest\")\n  --json          Output JSON\n  -h, --help      display help for command"}],"details":{"status":"completed","exitCode":0,"durationMs":266,"aggregated":"Usage: clawhub explore [options]\n\nBrowse latest updated skills from the registry\n\nOptions:\n  --limit <n>     Number of skills to show (max 200) (default: 25)\n  --sort <order>  Sort by newest, downloads, rating, installs, installsAllTime,\n                  or trending (default: \"newest\")\n  --json          Output JSON\n  -h, --help      display help for command","cwd":"/Users/yanxin/.openclaw/workspace"},"isError":false,"timestamp":1773369227221}}
