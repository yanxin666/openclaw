\"resvNum\":null,\"receiveFlag\":false,\"signUp\":false,\"visitedResv\":false}}"}],"timestamp":1773378792194}}
{"type":"message","id":"6d411fdc","parentId":"16571e1b","timestamp":"2026-03-13T05:14:22.874Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"太好了！用户提供了完整的API请求和响应信息。现在我明白了问题所在：\n\n**API信息：**\n- URL: `https://b1001.n8.bjmantis.cn/msp-war/customer/queryCustomerByCopy.do`（注意域名是 b1001，不是我之前监听的 b1003）\n- 请求方法: POST\n- 请求体: JSON，包含 customerId, sign, type, copyValueType 等字段\n- 响应体: JSON，包含 `data.phone1` 字段，值为 `\"13588606953\"`（解密后的完整手机号）\n\n**关键发现：**\n1. API URL 是 `b1001.n8.bjmantis.cn`，不是 `b1003.n8.bjmantis.cn`\n2. 需要传递 `customerId` 和 `sign` 参数\n3. 需要正确的请求头，包括 Authorization, nonce, sign, timestamp 等\n4. 响应中的 `data.phone1` 包含解密后的手机号\n\n现在我需要创建一个脚本，能够：\n1. 从页面中提取 customerId\n2. 构造正确的请求参数\n3. 发送POST请求到正确的API\n4. 解析响应获取解密后的手机号\n\n但是我注意到一个问题：请求需要很多认证信息，包括：\n- Authorization header\n- nonce\n- sign\n- timestamp\n\n这些都是动态生成的，很难在Python脚本中模拟。最好的方法还是：\n\n\n我发现了两种可行的方案来获取解密手机号。第一种是直接监听API响应，第二种是利用Playwright的`page.evaluate()`方法在浏览器环境中模拟点击操作。这两种方法都能绕过复杂的认证挑战，直接获取所需信息。","thinkingSignature":"reasoning_content"},{"type":"text","text":"完美！我现在知道问题所在了！🎉\n\n**关键发现：**\n1. ✅ API URL 是 `b1001.n8.bjmantis.cn`（不是我监听的 b1003）\n2. ✅ 响应格式：`data.phone1` 包含解密后的手机号 `\"13588606953\"`\n3. ✅ 需要正确的请求头和签名\n\n现在我来创建一个修正版本，监听正确的API并获取解密手机号："},{"type":"toolCall","id":"call_e9d99400974a4bfaa2722f0d","name":"write","arguments":{"content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n网站数据抓取脚本 - 最终修正版（正确的API监听）\n根据实际API信息修正\n\"\"\"\n\nimport time\nimport csv\nimport os\nimport re\nfrom playwright.sync_api import sync_playwright\n\nOUTPUT_FILE = \"/Users/yanxin/.openclaw/workspace/tmp/user.csv\"\n\n# 全局变量存储解密后的手机号\nlast_decrypted_phone = None\n\ndef setup_api_listener(page):\n    \"\"\"监听解密API响应（修正版）\"\"\"\n    def handle_response(response):\n        global last_decrypted_phone\n        \n        # 监听正确的域名和路径\n        url = response.url\n        if \"queryCustomerByCopy\" in url and (\"b1001\" in url or \"b1003\" in url or \"b100\" in url):\n            try:\n                data = response.json()\n                print(f\"\\n      📡 API响应捕获: {url}\")\n                \n                if \"data\" in data and \"phone1\" in data[\"data\"]:\n                    phone = data[\"data\"][\"phone1\"]\n                    last_decrypted_phone = phone\n                    print(f\"      ✅ 成功获取解密手机号: {phone}\")\n            except Exception as e:\n                print(f\"      ⚠️  解析失败: {e}\")\n    \n    page.on(\"response\", handle_response)\n\ndef extract_masked_phone(cell):\n    \"\"\"提取脱敏手机号\"\"\"\n    try:\n        phone_elem = cell.locator(\"a.Show_Data_In_A_Row\").first\n        if phone_elem.count() > 0:\n            title = phone_elem.get_attribute(\"title\")\n            if title and \"****\" in title:\n                return title.strip()\n            \n            text = phone_elem.inner_text(timeout=500)\n            if text and \"****\" in text:\n                return text.strip()\n    except:\n        pass\n    \n    try:\n        all_text = cell.inner_text(timeout=500)\n        match = re.search(r'\\d{3}\\*{4}\\d{4}', all_text)\n        if match:\n            return match.group()\n    except:\n        pass\n    \n    return \"空\"\n\ndef click_decrypt_button(page, cell):\n    \"\"\"点击解密按钮并获取解密后的手机号\"\"\"\n    global last_decrypted_phone\n    \n    try:\n        # 查找解密按钮\n        decrypt_btn = cell.locator('i[title=\"复制联系电话\"]').first\n        \n        if decrypt_btn.count() > 0 and decrypt_btn.is_visible(timeout=500):\n            # 重置全局变量\n            last_decrypted_phone = None\n            \n            # 点击按钮\n            decrypt_btn.click(timeout=1000)\n            \n            # 等待API响应（最多5秒）\n            for i in range(10):\n                time.sleep(0.5)\n                if last_decrypted_phone:\n                    return last_decrypted_phone\n            \n    except Exception as e:\n        pass\n    \n    return \"空\"\n\ndef parse_cell_text(cell, default=\"空\"):\n    \"\"\"解析单元格文本\"\"\"\n    try:\n        elem = cell.locator(\"[title]\").first\n        if elem.count() > 0:\n            text = elem.get_attribute(\"title\")\n            if text and text.strip():\n                return text.strip()\n        \n        text = cell.inner_text(timeout=500).strip()\n        text = text.replace(\"\\xa0\", \"\").strip()\n        return text if text else default\n    except:\n        return default\n\ndef scrape_page(page):\n    \"\"\"抓取当前页\"\"\"\n    members = []\n    time.sleep(2)\n    \n    try:\n        rows = page.locator(\".ant-table-row.ant-table-row-level-0\").all()\n        if not rows:\n            print(\"   ⚠️  当前页没有数据\")\n            return members\n        \n        print(f\"   找到 {len(rows)} 条记录\\n\")\n        \n        for idx, row in enumerate(rows, 1):\n            try:\n                cells = row.locator(\"td\").all()\n                \n                if len(cells) < 23:\n                    continue\n                \n                # 提取联系电话（索引3）\n                phone_cell = cells[3]\n                masked_phone = extract_masked_phone(phone_cell)\n                \n                if masked_phone == \"空\":\n                    print(f\"   [{idx:2d}] ⚠️  无法提取脱敏手机号，跳过\")\n                    continue\n                \n                # 点击解密按钮\n                print(f\"   [{idx:2d}] {parse_cell_text(cells[6]):10s}\", end=\"\", flush=True)\n                decrypted_phone = click_decrypt_button(page, phone_cell)\n                \n                # 如果解密成功，使用解密后的手机号；否则使用脱敏号码\n                final_phone = decrypted_phone if decrypted_phone != \"空\" else masked_phone\n                \n                fields = {\n                    \"联系电话\": final_phone,\n                    \"意向度\": parse_cell_text(cells[4]),\n                    \"来源名称\": parse_cell_text(cells[5]),\n                    \"姓名\": parse_cell_text(cells[6]),\n                    \"微信\": parse_cell_text(cells[7]),\n                    \"QQ\": parse_cell_text(cells[8]),\n                    \"咨询项目\": parse_cell_text(cells[9]),\n                    \"省份\": parse_cell_text(cells[10]),\n                    \"地域\": parse_cell_text(cells[11]),\n                    \"首次咨询时间\": parse_cell_text(cells[12]),\n                    \"过期时间\": parse_cell_text(cells[13]),\n                    \"最后咨询时间\": parse_cell_text(cells[14]),\n                    \"下次回访时间\": parse_cell_text(cells[15]),\n                    \"分配类型\": parse_cell_text(cells[16]),\n                    \"备注\": parse_cell_text(cells[17]),\n                    \"标签\": parse_cell_text(cells[18]),\n                    \"当日外呼次数\": parse_cell_text(cells[19]),\n                    \"当日呼通的次数\": parse_cell_text(cells[20]),\n                    \"当日接通时长\": parse_cell_text(cells[21]),\n                    \"广告商\": parse_cell_text(cells[22])\n                }\n                \n                members.append(fields)\n                \n                if decrypted_phone != \"空\":\n                    print(f\" ✅ {masked_phone} -> {final_phone}\")\n                else:\n                    print(f\" ⚠️  {masked_phone} (未解密)\")\n                \n                # 间隔1秒，避免触发限频\n                time.sleep(1)\n                \n            except Exception as e:\n                print(f\" ❌ 失败: {e}\")\n                continue\n        \n    except Exception as e:\n        print(f\"   ❌ 抓取失败: {e}\")\n    \n    return members\n\ndef next_page(page):\n    \"\"\"翻页\"\"\"\n    try:\n        btn = page.locator(\".ant-pagination-next:not(.ant-pagination-disabled)\").first\n        if btn.count() > 0 and btn.is_visible(timeout=1000) and btn.is_enabled(timeout=1000):\n            btn.click()\n            print(\"   🔄 已翻到下一页\")\n            time.sleep(2)\n            return True\n        print(\"   ℹ️  已到最后一页\")\n        return False\n    except:\n        return False\n\ndef save_csv(data, filename):\n    \"\"\"保存CSV\"\"\"\n    if not data:\n        print(\"\\n⚠️  没有数据可保存\")\n        return False\n    \n    os.makedirs(os.path.dirname(filename), exist_ok=True)\n    \n    fieldnames = [\n        \"联系电话\", \"意向度\", \"来源名称\", \"姓名\", \"微信\", \"QQ\", \n        \"咨询项目\", \"省份\", \"地域\", \"首次咨询时间\", \"过期时间\", \n        \"最后咨询时间\", \"下次回访时间\", \"分配类型\", \"备注\", \"标签\",\n        \"当日外呼次数\", \"当日呼通的次数\", \"当日接通时长\", \"广告商\"\n    ]\n    \n    with open(filename, 'w', newline='', encoding='utf-8-sig') as f:\n        writer = csv.DictWriter(f, fieldnames=fieldnames)\n        writer.writeheader()\n        writer.writerows(data)\n    \n    print(f\"\\n✅ 数据已保存到: {filename}\")\n    print(f\"📊 共保存 {len(data)} 条记录\")\n    return True\n\ndef main():\n    print(\"\\n\" + \"=\"*60)\n    print(\"🚀 网站数据抓取工具（最终修正版）\")\n    print(\"=\"*60)\n    \n    with sync_playwright() as p:\n        print(\"\\n🌐 正在启动浏览器...\")\n        browser = p.chromium.launch(headless=False)\n        page = browser.new_page()\n        \n        setup_api_listener(page)\n        \n        try:\n            page.goto(\"https://hbsxzxjykjyxgs.n4.bjmantis.cn/\", wait_until=\"networkidle\")\n            \n            print(\"\\n\" + \"=\"*60)\n            print(\"⚠️  请手动完成：\")\n            print(\"   1. 登录系统\")\n            print(\"   2. 导航到【电销客户管理/我的客户/回访】\")\n            print(\"   3. 确认页面已显示表格数据\")\n            print(\"=\"*60)\n            \n            input(\"\\n✅ 完成后按回车开始抓取...\")\n            \n            all_members = []\n            page_num = 1\n            \n            print(f\"\\n🔍 开始抓取数据（带解密手机号）...\\n\")\n            \n            while True:\n                print(\"=\"*60)\n                print(f\"📄 第 {page_num} 页\")\n                print(\"=\"*60)\n                \n                members = scrape_page(page)\n                all_members.extend(members)\n                \n                print(\"\\n   🔄 准备翻页...\")\n                if not next_page(page):\n                    break\n                \n                page_num += 1\n                time.sleep(1)\n            \n            if all_members:\n                save_csv(all_members