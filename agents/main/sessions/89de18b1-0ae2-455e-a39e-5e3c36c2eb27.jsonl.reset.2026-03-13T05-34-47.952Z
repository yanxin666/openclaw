\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_fifteen\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_sixteen\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_seventeen\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_eighteen\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_nineteen\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_twenty\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_twenty_one\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_twenty_two\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_twenty_three\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_twenty_four\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_twenty_five\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_twenty_six\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_twenty_seven\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_twenty_eignt\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_twenty_nine\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_thirty\":{\"itemCode\":null,\"itemValue\":null,\"companyId\":null,\"type\":\"MSP_CUSTOMIZE_FIELD_DICT\"},\"field_thirty_one\":{\"itemCode\":null,\"itemValue\":null,\"